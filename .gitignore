# Build binaries
/tui
/24-markdown
dist/

# Example binaries (compiled Go binaries match their directory name)
# Ignore everything, then un-ignore source files and known subdirectories
examples/*/*
!examples/**/*.go
!examples/**/*.gsx
!examples/**/*.md
!examples/**/*.mod
!examples/**/*.sum
!examples/**/settings/

# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
vendor/

# IDE/Editor
.idea/
.vscode/*
# Track shared project settings (file nesting for generated *_gsx.go), ignore personal cruft
!.vscode/settings.json
*.swp
*.swo
*~

# Editor extensions (preserve source, ignore build artifacts)
!editor/vscode/
editor/vscode/out/
editor/vscode/node_modules/
editor/tree-sitter-gsx/build/
editor/tree-sitter-gsx/node_modules/
editor/zed-gsx/grammars/gsx/
editor/zed-gsx/target/
*.vsix
extension.wasm

# Node
node_modules/

# Docs site
docs/dist/
docs/node_modules/
docs/plans

# Superpowers specs and plans (kept locally, not tracked)
docs/superpowers/

